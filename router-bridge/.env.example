# 1. Firebase Authentication & Project Settings
# These can be copied directly from your firebase-applet-config.json file.
FIREBASE_PROJECT_ID=kelgralich-f1358
FIREBASE_APP_ID=1:1091277032902:web:6d60454c168283aaa2f6c7
FIREBASE_API_KEY=AIzaSyACknEp5ZnuUkDeMVA-zuMiSa2R73nbdDw
FIREBASE_AUTH_DOMAIN=kelgralich-f1358.firebaseapp.com
FIREBASE_FIRESTORE_DB_ID=
FIREBASE_STORAGE_BUCKET=kelgralich-f1358.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=1091277032902

# 2. Operator Login Credentials
# Create this user in your Admin Panel or Firebase Console under Authentication.
# The bridge uses this account to authenticate and gain write permissions to Firestore.
FIREBASE_OPERATOR_EMAIL=admin@airtel-hotspot.co.tz
FIREBASE_OPERATOR_PASSWORD=AirtelTZHotspot2026!

# 3. Physical MikroTik Router Settings
# Ensure API service is enabled on your MikroTik under: /ip service enable api
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=admin_password
MIKROTIK_PORT=8728

# 4. Synchronization Intervals
# Frequency of checking expired sessions and writing connected active users to Firestore (in seconds).
SYNC_INTERVAL_SEC=15
